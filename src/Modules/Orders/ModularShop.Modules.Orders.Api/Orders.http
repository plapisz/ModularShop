###
GET {{url}}/home
Accept: application/json

###
GET {{url}}
Authorization: Bearer {{accessToken}}
Accept: application/json

###
GET {{url}}/{{orderId}}
Authorization: Bearer {{accessToken}}
Accept: application/json

###
GET {{url}}/customer/{{customerId}}
Authorization: Bearer {{accessToken}}
Accept: application/json

###
POST {{url}}
Authorization: Bearer {{accessToken}}
Content-Type: application/json

{
  "customerId": "{{customerId}}"
}

###
POST {{url}}/{{orderId}}/items
Authorization: Bearer {{accessToken}}
Content-Type: application/json

{
  "productId": "{{productId}}",
  "quantity": 2
}

###
DELETE {{url}}/{{orderId}}/items/{{productId}}
Authorization: Bearer {{accessToken}}

###
